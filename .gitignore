# =============================================================================
# Samato bible .gitignore
# =============================================================================
# This file lives at the project root. Sub-modules inherit these patterns.
# =============================================================================

# ─── Build outputs ─────────────────────────────────────────────────────────
# Maven
target/
**/target/
*.class
*.jar
*.war
*.ear
.flattened-pom.xml

# Gradle (not used, but harmless to keep)
.gradle/
build/
out/

# ─── IDE and editor files ──────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/
.factorypath
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── OS junk ───────────────────────────────────────────────────────────────
$RECYCLE.BIN/
ehthumbs.db
Desktop.ini

# ─── Local environment and secrets ─────────────────────────────────────────
# Per-environment overrides (NEVER commit)
.env
.env.local
.env.*.local
application-local.yml
application-local.properties
application-local.yaml
**/application-local.*

# Local credentials (anything real-looking)
*.pem
*.key
*.p12
*.pfx
keystore.jks
truststore.jks
secrets.yml
secrets.yaml

# ─── Logs and runtime ──────────────────────────────────────────────────────
*.log
logs/
**/logs/
spring.log
hs_err_pid*.log
replay_pid*.log
nohup.out

# ─── Testing and coverage ──────────────────────────────────────────────────
jacoco.exec
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/
coverage.xml
*.lcov

# ─── Docker and infra ──────────────────────────────────────────────────────
# Keep docker-compose.yml, ignore any local volume mounts or data
*.pid
docker-data/
postgres-data/
kafka-data/
redis-data/

# ─── Node / JS bits that might sneak in ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Spring Boot devtools ──────────────────────────────────────────────────
spring-boot-devtools.properties
restart/
