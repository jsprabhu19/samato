        {
          "name": "Seed owner role via SQL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://example.com/seed-owner",
              "host": [
                "example",
                "com"
              ],
              "path": [
                "seed-owner"
              ]
            },
            "description": "DOCUMENTATION REQUEST. Public registration always creates a CUSTOMER. To make Bob (ownerEmail) a RESTAURANT_OWNER you must promote his role in the database. Run the psql command logged by this request's Tests script. The test always passes — the SQL is the real work."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('MANUAL STEP: Run this in your terminal to make Bob a RESTAURANT_OWNER:');",
                  "console.log('');",
                  "console.log('docker exec -it samato-postgres psql -U fd -d auth_service -c \"UPDATE user_roles SET roles = ARRAY[\\'RESTAURANT_OWNER\\'] WHERE user_id = (SELECT id FROM users WHERE email = \\'bob@example.com\\');\"');",
                  "console.log('');",
                  "console.log('If that table name is different, run: docker exec -it samato-postgres psql -U fd -d auth_service -c \"\\\\dt\" to list tables first.');",
                  "pm.test('seed owner role manual step acknowledged', () => {",
                  "    pm.expect(true).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
