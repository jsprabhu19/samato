          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('gateway health is UP', () => {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.include('UP');",
                  "});"
