{
  "endpoints": [
    {
      "service": "auth-service",
      "verb": "POST",
      "path": "/api/auth/register",
      "handlerClass": "RegistrationController",
      "handlerMethod": "register",
      "requestDto": "RegisterRequest",
      "responseDto": "RegisterResponse",
      "guards": ["permitAll (default chain)"],
      "useCases": ["auth-flow", "how-auth-works"]
    },
    {
      "service": "auth-service",
      "verb": "GET",
      "path": "/api/auth/me",
      "handlerClass": "MeController",
      "handlerMethod": "me",
      "requestDto": "none",
      "responseDto": "MeResponse",
      "guards": ["authenticated (default chain); user-not-found if JWT subject missing from DB"],
      "useCases": ["auth-flow", "how-auth-works"]
    },
    {
      "service": "auth-service",
      "verb": "GET",
      "path": "/api/auth/debug/token",
      "handlerClass": "TokenDebugController",
      "handlerMethod": "debug",
      "requestDto": "none",
      "responseDto": "DebugView",
      "guards": ["authenticated; not exposed via gateway"],
      "useCases": ["how-auth-works"]
    },
    {
      "service": "auth-service",
      "verb": "GET",
      "path": "/api/auth/dev-token",
      "handlerClass": "DevTokenController",
      "handlerMethod": "devToken",
      "requestDto": "query: email",
      "responseDto": "Map{access_token, token_type, expires_in, scope}",
      "guards": ["@Profile({'dev','default'}); permitAll in default chain"],
      "useCases": ["auth-flow", "how-auth-works"]
    },
    {
      "service": "auth-service",
      "verb": "GET",
      "path": "/.well-known/jwks.json",
      "handlerClass": "JwksController",
      "handlerMethod": "jks",
      "requestDto": "none",
      "responseDto": "JWKSet JSON (public keys only)",
      "guards": ["permitAll (default chain); /well-known/**"],
      "useCases": ["how-auth-works"]
    },
    {
      "service": "auth-service",
      "verb": "*",
      "path": "/oauth2/**",
      "handlerClass": "SpringAuthorizationServer (AuthServerConfig#authServerFilterChain)",
      "handlerMethod": "n/a (framework endpoints: /oauth2/token, /oauth2/authorize, /oauth2/jwks, /oauth2/revoke, etc.)",
      "requestDto": "OAuth2 standard",
      "responseDto": "OAuth2 standard",
      "guards": ["@Order(1) authServerFilterChain; /oauth2/**, /.well-known/openid-configuration"],
      "useCases": ["how-auth-works"]
    },
    {
      "service": "order-service",
      "verb": "POST",
      "path": "/api/orders",
      "handlerClass": "OrderController",
      "handlerMethod": "place",
      "requestDto": "OrderDtos.PlaceOrderRequest",
      "responseDto": "OrderDtos.OrderResponse",
      "guards": ["@PreAuthorize(\"hasRole('CUSTOMER')\")"],
      "useCases": ["place-an-order"]
    },
    {
      "service": "order-service",
      "verb": "GET",
      "path": "/api/orders/{id}",
      "handlerClass": "OrderController",
      "handlerMethod": "get",
      "requestDto": "path: id",
      "responseDto": "OrderDtos.OrderResponse",
      "guards": ["@PreAuthorize(\"hasAnyRole('CUSTOMER','ADMIN')\") + ownership check (subject == customerId or ADMIN)"],
      "useCases": ["place-an-order"]
    },
    {
      "service": "order-service",
      "verb": "GET",
      "path": "/api/orders",
      "handlerClass": "OrderController",
      "handlerMethod": "list",
      "requestDto": "none",
      "responseDto": "List<OrderDtos.OrderResponse>",
      "guards": ["@PreAuthorize(\"hasRole('CUSTOMER')\")"],
      "useCases": ["place-an-order"]
    },
    {
      "service": "order-service",
      "verb": "GET",
      "path": "/api/orders/{id}/saga",
      "handlerClass": "OrderController",
      "handlerMethod": "saga",
      "requestDto": "path: id",
      "responseDto": "Map<String,Object>",
      "guards": ["@PreAuthorize(\"hasAnyRole('CUSTOMER','ADMIN')\") + ownership check"],
      "useCases": ["place-an-order"]
    },
    {
      "service": "payment-service",
      "verb": "POST",
      "path": "/api/payments/orders",
      "handlerClass": "PaymentController",
      "handlerMethod": "createOrder",
      "requestDto": "PaymentDtos.CreatePaymentRequest",
      "responseDto": "PaymentDtos.PaymentResponse",
      "guards": ["@RequestHeader Idempotency-Key required; called internally by order-service saga (no @PreAuthorize at controller level — see security config)"],
      "useCases": ["place-an-order"]
    },
    {
      "service": "payment-service",
      "verb": "GET",
      "path": "/api/payments/{id}",
      "handlerClass": "PaymentController",
      "handlerMethod": "get",
      "requestDto": "path: id",
      "responseDto": "PaymentDtos.PaymentResponse",
      "guards": ["authenticated"],
      "useCases": ["place-an-order", "refund-flow"]
    },
    {
      "service": "payment-service",
      "verb": "GET",
      "path": "/api/payments/by-order/{orderId}",
      "handlerClass": "PaymentController",
      "handlerMethod": "getByOrder",
      "requestDto": "path: orderId",
      "responseDto": "PaymentDtos.PaymentResponse",
      "guards": ["authenticated"],
      "useCases": ["place-an-order", "refund-flow"]
    },
    {
      "service": "payment-service",
      "verb": "GET",
      "path": "/api/payments/{id}/events",
      "handlerClass": "PaymentController",
      "handlerMethod": "events",
      "requestDto": "path: id",
      "responseDto": "List<PaymentDtos.EventResponse>",
      "guards": ["authenticated (debug/audit)"],
      "useCases": ["place-an-order", "refund-flow"]
    },
    {
      "service": "payment-service",
      "verb": "GET",
      "path": "/api/payments/{id}/balance-at/{version}",
      "handlerClass": "PaymentController",
      "handlerMethod": "balanceAt",
      "requestDto": "path: id, version",
      "responseDto": "PaymentDtos.BalanceAtResponse",
      "guards": ["authenticated"],
      "useCases": ["place-an-order", "refund-flow"]
    },
    {
      "service": "payment-service",
      "verb": "POST",
      "path": "/api/payments/{id}/refunds",
      "handlerClass": "PaymentController",
      "handlerMethod": "refund",
      "requestDto": "PaymentDtos.RefundRequest",
      "responseDto": "PaymentDtos.PaymentResponse",
      "guards": ["@RequestHeader Idempotency-Key required; ADMIN-only (per javadoc)"],
      "useCases": ["refund-flow"]
    },
    {
      "service": "payment-service",
      "verb": "POST",
      "path": "/api/payments/webhooks/razorpay",
      "handlerClass": "WebhookController",
      "handlerMethod": "handle",
      "requestDto": "raw JSON body",
      "responseDto": "void (200/401/500)",
      "guards": ["HMAC SHA-256 X-Razorpay-Signature verification; separate SecurityFilterChain (permitAll), no JWT"],
      "useCases": ["place-an-order", "refund-flow"]
    },
    {
      "service": "restaurant-service",
      "verb": "GET",
      "path": "/api/restaurants/{id}",
      "handlerClass": "RestaurantController",
      "handlerMethod": "get",
      "requestDto": "path: id",
      "responseDto": "Restaurant",
      "guards": ["@PreAuthorize(\"isAuthenticated()\")"],
      "useCases": ["browse-and-search"]
    },
    {
      "service": "restaurant-service",
      "verb": "GET",
      "path": "/api/restaurants?city=...",
      "handlerClass": "RestaurantController",
      "handlerMethod": "findByCity",
      "requestDto": "query: city",
      "responseDto": "List<Restaurant>",
      "guards": ["@PreAuthorize(\"isAuthenticated()\")"],
      "useCases": ["browse-and-search"]
    },
    {
      "service": "restaurant-service",
      "verb": "GET",
      "path": "/api/restaurants/{id}/menu",
      "handlerClass": "RestaurantController",
      "handlerMethod": "getMenu",
      "requestDto": "path: id",
      "responseDto": "List<MenuItem>",
      "guards": ["@PreAuthorize(\"isAuthenticated()\")"],
      "useCases": ["browse-and-search"]
    },
    {
      "service": "restaurant-service",
      "verb": "POST",
      "path": "/api/restaurants",
      "handlerClass": "RestaurantController",
      "handlerMethod": "create",
      "requestDto": "CreateRestaurantRequest",
      "responseDto": "Restaurant",
      "guards": ["@PreAuthorize(\"hasRole('RESTAURANT_OWNER')\")"],
      "useCases": ["browse-and-search"]
    },
    {
      "service": "restaurant-service",
      "verb": "PUT",
      "path": "/api/restaurants/{id}",
      "handlerClass": "RestaurantController",
      "handlerMethod": "update",
      "requestDto": "UpdateRestaurantRequest",
      "responseDto": "Restaurant",
      "guards": ["@PreAuthorize(\"hasRole('ADMIN') or @restaurantOwnership.isOwner(#id, authentication)\")"],
      "useCases": ["browse-and-search"]
    },
    {
      "service": "restaurant-service",
      "verb": "DELETE",
      "path": "/api/restaurants/{id}",
      "handlerClass": "RestaurantController",
      "handlerMethod": "deactivate",
      "requestDto": "path: id",
      "responseDto": "void (204)",
      "guards": ["@PreAuthorize(\"hasRole('ADMIN') or @restaurantOwnership.isOwner(#id, authentication)\")"],
      "useCases": ["browse-and-search"]
    },
    {
      "service": "restaurant-service",
      "verb": "POST",
      "path": "/api/restaurants/{id}/menu",
      "handlerClass": "RestaurantController",
      "handlerMethod": "addMenuItem",
      "requestDto": "CreateMenuItemRequest",
      "responseDto": "MenuItem",
      "guards": ["@PreAuthorize(\"hasRole('ADMIN') or @restaurantOwnership.isOwner(#id, authentication)\")"],
      "useCases": ["browse-and-search"]
    },
    {
      "service": "search-service",
      "verb": "GET",
      "path": "/api/search/restaurants",
      "handlerClass": "SearchController",
      "handlerMethod": "search",
      "requestDto": "query: q, cuisine, city, lat, lon, radiusKm, size",
      "responseDto": "SearchResponse",
      "guards": ["@PreAuthorize(\"isAuthenticated()\")"],
      "useCases": ["browse-and-search"]
    },
    {
      "service": "user-service",
      "verb": "GET",
      "path": "/api/users/me",
      "handlerClass": "CustomerProfileController",
      "handlerMethod": "getMine",
      "requestDto": "none",
      "responseDto": "CustomerProfile",
      "guards": ["@PreAuthorize(\"isAuthenticated()\")"],
      "useCases": ["auth-flow"]
    },
    {
      "service": "user-service",
      "verb": "PUT",
      "path": "/api/users/me",
      "handlerClass": "CustomerProfileController",
      "handlerMethod": "updateMine",
      "requestDto": "UpdateProfileRequest",
      "responseDto": "CustomerProfile",
      "guards": ["@PreAuthorize(\"isAuthenticated()\")"],
      "useCases": ["auth-flow"]
    },
    {
      "service": "user-service",
      "verb": "GET",
      "path": "/api/users/{id}",
      "handlerClass": "CustomerProfileController",
      "handlerMethod": "getById",
      "requestDto": "path: id",
      "responseDto": "CustomerProfile",
      "guards": ["@PreAuthorize(\"hasRole('ADMIN') or authentication.name == #id.toString()\")"],
      "useCases": ["auth-flow"]
    },
    {
      "service": "user-service",
      "verb": "GET",
      "path": "/api/users/drivers/me",
      "handlerClass": "DriverProfileController",
      "handlerMethod": "getMine",
      "requestDto": "none",
      "responseDto": "DriverProfile",
      "guards": ["@PreAuthorize(\"hasRole('DRIVER')\")"],
      "useCases": ["auth-flow"]
    },
    {
      "service": "user-service",
      "verb": "PUT",
      "path": "/api/users/drivers/me",
      "handlerClass": "DriverProfileController",
      "handlerMethod": "updateMine",
      "requestDto": "UpdateRequest",
      "responseDto": "DriverProfile",
      "guards": ["@PreAuthorize(\"hasRole('DRIVER')\")"],
      "useCases": ["auth-flow"]
    },
    {
      "service": "user-service",
      "verb": "PUT",
      "path": "/api/users/drivers/me/location",
      "handlerClass": "DriverProfileController",
      "handlerMethod": "updateLocation",
      "requestDto": "LocationUpdate",
      "responseDto": "DriverProfile",
      "guards": ["@PreAuthorize(\"hasRole('DRIVER')\")"],
      "useCases": ["auth-flow"]
    },
    {
      "service": "user-service",
      "verb": "GET",
      "path": "/api/users/drivers/on-duty",
      "handlerClass": "DriverProfileController",
      "handlerMethod": "listOnDuty",
      "requestDto": "none",
      "responseDto": "List<DriverProfile>",
      "guards": ["@PreAuthorize(\"hasRole('DRIVER') or hasRole('ADMIN')\")"],
      "useCases": ["auth-flow"]
    },
    {
      "service": "user-service",
      "verb": "GET",
      "path": "/api/users/restaurant-owners/me",
      "handlerClass": "RestaurantOwnerProfileController",
      "handlerMethod": "getMine",
      "requestDto": "none",
      "responseDto": "RestaurantOwnerProfile",
      "guards": ["@PreAuthorize(\"hasRole('RESTAURANT_OWNER')\")"],
      "useCases": ["auth-flow"]
    },
    {
      "service": "user-service",
      "verb": "PUT",
      "path": "/api/users/restaurant-owners/me",
      "handlerClass": "RestaurantOwnerProfileController",
      "handlerMethod": "updateMine",
      "requestDto": "UpdateRequest",
      "responseDto": "RestaurantOwnerProfile",
      "guards": ["@PreAuthorize(\"hasRole('RESTAURANT_OWNER')\")"],
      "useCases": ["auth-flow"]
    },
    {
      "service": "api-gateway",
      "verb": "*",
      "path": "/api/auth/**",
      "handlerClass": "GatewayRoutesConfig#routes (Spring Cloud Gateway RouteLocator)",
      "handlerMethod": "n/a (route id: samato-auth-service)",
      "requestDto": "n/a",
      "responseDto": "n/a",
      "guards": ["public route; no JWT filter"],
      "useCases": ["auth-flow", "how-auth-works"]
    },
    {
      "service": "api-gateway",
      "verb": "*",
      "path": "/api/users/**",
      "handlerClass": "GatewayRoutesConfig#routes",
      "handlerMethod": "n/a (route id: samato-user-service)",
      "requestDto": "n/a",
      "responseDto": "n/a",
      "guards": ["JWT filter applied; per-service @PreAuthorize further restricts"],
      "useCases": ["auth-flow", "how-auth-works"]
    },
    {
      "service": "api-gateway",
      "verb": "*",
      "path": "/api/orders/**",
      "handlerClass": "GatewayRoutesConfig#routes",
      "handlerMethod": "n/a (route id: samato-order-service)",
      "requestDto": "n/a",
      "responseDto": "n/a",
      "guards": ["JWT filter applied; per-service @PreAuthorize further restricts"],
      "useCases": ["place-an-order", "how-auth-works"]
    },
    {
      "service": "api-gateway",
      "verb": "*",
      "path": "/api/restaurants/**",
      "handlerClass": "GatewayRoutesConfig#routes",
      "handlerMethod": "n/a (route id: samato-restaurant-service)",
      "requestDto": "n/a",
      "responseDto": "n/a",
      "guards": ["JWT filter applied; per-service @PreAuthorize further restricts"],
      "useCases": ["browse-and-search", "how-auth-works"]
    },
    {
      "service": "api-gateway",
      "verb": "*",
      "path": "/api/search/**",
      "handlerClass": "GatewayRoutesConfig#routes",
      "handlerMethod": "n/a (route id: samato-search-service)",
      "requestDto": "n/a",
      "responseDto": "n/a",
      "guards": ["JWT filter applied"],
      "useCases": ["browse-and-search", "how-auth-works"]
    },
    {
      "service": "api-gateway",
      "verb": "*",
      "path": "/api/payments/**",
      "handlerClass": "GatewayRoutesConfig#routes",
      "handlerMethod": "n/a (route id: samato-payment-service)",
      "requestDto": "n/a",
      "responseDto": "n/a",
      "guards": ["JWT filter applied; payment-service has separate chain for /api/payments/webhooks/** (HMAC)"],
      "useCases": ["place-an-order", "refund-flow", "how-auth-works"]
    },
    {
      "service": "api-gateway",
      "verb": "*",
      "path": "/actuator/**",
      "handlerClass": "GatewayRoutesConfig#routes",
      "handlerMethod": "n/a (route id: health)",
      "requestDto": "n/a",
      "responseDto": "n/a",
      "guards": ["public (K8s probes)"],
      "useCases": []
    }
  ],
